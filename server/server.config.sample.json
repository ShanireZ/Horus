{
  // 监考服务器配置**样例(模板·已提交进 git 公开仓库)**。复制为 server.config.json(已 gitignore)后按现场填真值。
  // ⚠️ 切勿把真实密钥 / API key 填进本 sample 文件 —— 会随提交泄漏到公开仓库。真值只放 server.config.json。
  "urls": "http://0.0.0.0:5199",
  "dataDir": "./data",
  "dbPath": "horus.db",
  // 预共享 HMAC 密钥(base64),必须与各 Agent 的 psk 一致。
  // 留空 = 关闭验签(仅本机联调用;生产务必配置)。
  // 生成示例(PowerShell): [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
  "pskBase64": "",
  // 击键旁路密钥(base64):判题后端持它对 /ingest/keystroke 提交体签名(X-Horus-KSig)。
  // 留空 = 关闭击键鉴权(仅联调)。生产接了判题埋点应配置,否则同网学员机可伪造/栽赃他人击键样本。与 psk 相互独立。
  "keystrokeSecretBase64": "",
  // 管理/看板令牌:所有 /api/*(除 /api/login、/api/logout)需带凭证。
  //   浏览器:POST /api/login {token} 校验后种 HttpOnly cookie(JS 读不到、不进 URL)——首选;
  //   脚本客户端:X-Horus-Admin 头;图片字节端点兼容 ?t= 查询。
  // 留空 = 关闭管理鉴权(仅联调)。生产务必配置,否则同网学员机可下发配置关掉全场检测/拉证据图/抹裁决。
  "adminToken": "",
  // 非 loopback 绑定时,缺采集鉴权(PSK 或 OIDC)或 adminToken 会拒绝启动(fail-closed)。仅本机联调可设 true 放行。
  "allowInsecure": false,
  // ---- M4 身份层:cpplearn OIDC 取代共享 PSK(见 docs/m4-identity-oidc.md)----
  // authMode: "psk"(默认·共享 PSK) | "oidc"(仅 OIDC 会话) | "both"(迁移共存·可回退 PSK)。
  "authMode": "psk",
  // OIDC issuer(cpplearn 对外根域名,如 https://betaoi.cc)。oidc/both 必配。
  "oidcIssuer": "",
  // Horus 在 cpplearn 注册的 client_id(与 cpplearn OAUTH_HORUS_CLIENT_ID 一致)。
  "oidcClientId": "horus-client",
  // client_secret 明文(仅联调;生产用 oidcClientSecretEnc DPAPI 或 env HORUS_OIDC_SECRET)。Server-Broker:secret 只在本服务器。
  "oidcClientSecret": "",
  "oidcClientSecretEnc": "",
  // cpplearn JWKS(RSA 公钥)内联 JSON:局域网离线验 id_token。留空则启动时从 issuer 拉取并缓存(需启动时可达 issuer)。
  "oidcJwksJson": "",
  // OIDC 会话有效期(分钟):派发的采集凭证寿命,建议 ≥ 考试时长。默认 180。
  "oidcSessionMinutes": 180,
  "riskThreshold": 50,
  "dedupImagesByPhash": true,
  "onlineWindowSeconds": 90,
  "recentRiskWindowSeconds": 300,
  // M3 归档 / 清理(architecture §13/§15):考试**结束**超 RetentionDays 天后,关键数据(可疑/裁决/高危事件+其证据图/OCR/击键)
  //   转入 archive 库、其余就地清理、status='archived'、VACUUM 回收空间。仍有 pending 未裁决的考试会**跳过**(不 purge 未决案证据)。
  "archiveEnabled": true,
  "retentionDays": 30,
  // 关键数据判据:事件有效风险(max(agent,server))≥ 此值,或被 suspicious_queue 引用。
  "archiveCriticalRisk": 50,
  // 归档库文件(相对 dataDir);后台扫描间隔小时(≤0=关后台,仍可手动 POST /api/archive/run 触发)。
  "archiveDbPath": "horus-archive.db",
  "archiveScanIntervalHours": 6,
  // 视觉分析(L2:视觉 LLM 取代 OCR + L3 Logo,合并单一视觉级)。一次调用做文字提取+界面/图标识别+分类。
  // visionProvider: 留空/off=关(默认) | mock(确定性·联调) | openai(OpenAI 兼容端点)。
  //   openai 通吃小米 MiMo-V2.5 / DeepSeek-V4 / Qwen-VL / GLM-4V —— 换供应商=换 baseUrl+model+key。
  //   ★ owner 选定 = 小米 MiMo-V2.5 托管 API(境内云,OpenAI 兼容):
  "visionProvider": "openai",
  "visionBaseUrl": "https://token-plan-cn.xiaomimimo.com/v1",
  "visionModel": "mimo-v2.5",
  // ★ API key:在 **server.config.json**(非本 sample)里把明文填到 visionApiKey,服务器启动会**自动加密**为下面的 visionApiKeyEnc 并**清空本字段**。
  "visionApiKey": "",
  // 自动生成的 DPAPI 密文(机器绑定·勿手改)。也可用 `Horus.Server protect-secret <key>` 预生成后直接填这里、visionApiKey 留空。
  "visionApiKeyEnc": "",
  "visionConfidenceThreshold": 60,
  "visionAnalyzeBaseline": false,
  // 补偿重扫间隔(分钟):周期性拾回被队列丢弃/重启丢内存队列/临时云失败的未分析触发型证据图。默认 5;≤0=关闭。
  "visionBackstopMinutes": 5,
  // 单张图视觉分析最大认领次数(含失败):临时云失败由补偿重扫重试,达此上限放弃防死循环。默认 5。
  "visionMaxAttempts": 5,
  // §5 送云前派生处理(owner 决策 2026-07-02:不再打码/裁剪,只降采样;供应商=境内云 MiMo·PIPL 无跨境):
  //   visionMaxEdge: 送云图长边像素上限(降采样省 token·顺带剥离 EXIF/XMP/ICC 元数据)。默认 1600;0=不降采样直通。原图永不出网,只送派生图。
  "visionMaxEdge": 1600
}