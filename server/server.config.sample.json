{
  // 监考服务器配置**样例(模板·已提交进 git 公开仓库)**。复制为 server.config.json(已 gitignore)后按现场填真值。
  // ⚠️ 切勿把真实密钥 / API key 填进本 sample 文件 —— 会随提交泄漏到公开仓库。真值只放 server.config.json。
  "urls": "http://0.0.0.0:5199",
  "dataDir": "./data",
  "dbPath": "horus.db",
  // 预共享 HMAC 密钥(base64),必须与各 Agent 的 psk 一致。
  // 留空 = 关闭验签(仅本机联调用;生产务必配置)。
  // 生成示例(PowerShell): [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
  "pskBase64": "",
  // 击键旁路密钥(base64):判题后端持它对 /ingest/keystroke 提交体签名(X-Horus-KSig)。
  // 留空 = 关闭击键鉴权(仅联调)。生产接了判题埋点应配置,否则同网学员机可伪造/栽赃他人击键样本。与 psk 相互独立。
  "keystrokeSecretBase64": "",
  // 管理/看板令牌:所有 /api/*(除 /api/login、/api/logout)需带凭证。
  //   浏览器:POST /api/login {token} 校验后种 HttpOnly cookie(JS 读不到、不进 URL)——首选;
  //   脚本客户端:X-Horus-Admin 头;图片字节端点兼容 ?t= 查询。
  // 留空 = 关闭管理鉴权(仅联调)。生产务必配置,否则同网学员机可下发配置关掉全场检测/拉证据图/抹裁决。
  "adminToken": "",
  // 非 loopback 绑定时,缺采集鉴权(PSK 或 OIDC)或 adminToken 会拒绝启动(fail-closed)。仅本机联调可设 true 放行。
  "allowInsecure": false,
  // 启动成功自动在默认浏览器打开管理端看板(仅交互式运行的真 exe;服务化/脚本运行不弹)。
  "openDashboard": true,
  // ---- M4 身份层:cpplearn OIDC 取代共享 PSK(见 docs/m4-identity-oidc.md)----
  // authMode: "psk"(默认·共享 PSK) | "oidc"(仅 OIDC 会话) | "both"(迁移共存·可回退 PSK)。
  "authMode": "psk",
  // OIDC issuer(cpplearn 对外根域名,如 https://betaoi.cc)。oidc/both 必配。
  "oidcIssuer": "",
  // Horus 在 cpplearn 注册的 client_id(与 cpplearn OAUTH_HORUS_CLIENT_ID 一致)。
  "oidcClientId": "horus-client",
  // client_secret:**把明文填进 oidcClientSecret,启动一次即自动加密为 oidcClientSecretEnc 并清空明文**(同 visionApiKey 机制·DPAPI)。
  //   也可 `Horus.Server protect-secret <secret>` 预生成密文直接填 Enc、明文留空;或 env HORUS_OIDC_SECRET 注入(不落盘)。Server-Broker:secret 只在本服务器。
  "oidcClientSecret": "",
  "oidcClientSecretEnc": "",
  // cpplearn JWKS(RSA 公钥)内联 JSON:局域网离线验 id_token。留空则启动时从 issuer 拉取并缓存(需启动时可达 issuer)。
  "oidcJwksJson": "",
  // OIDC 会话有效期(分钟):派发的采集凭证寿命,建议 ≥ 考试时长。默认 180。
  "oidcSessionMinutes": 180,
  // ---- M4·RBAC:监考员看板 OIDC 登录(cpplearn dashboard web client·取代静态 adminToken·见 §10)----
  // adminAuthMode: "token"(默认·静态 adminToken) | "oidc"(仅 cpplearn 长老 OIDC·R3 无令牌后门·监考员走 /admin/login)。
  "adminAuthMode": "token",
  // cpplearn dashboard web client_id(与 cpplearn OAUTH_HORUS_DASHBOARD_CLIENT_ID 一致)。adminAuthMode=oidc 必配。
  "oidcDashboardClientId": "horus-dashboard",
  // dashboard client_secret:**填明文进 oidcDashboardClientSecret,启动自动加密为 oidcDashboardClientSecretEnc 并清空明文**(同上)。
  //   亦可 protect-secret 预生成填 Enc,或 env HORUS_OIDC_DASHBOARD_SECRET 注入。
  "oidcDashboardClientSecret": "",
  "oidcDashboardClientSecretEnc": "",
  // dashboard 回调 URI:须与 cpplearn OAUTH_HORUS_DASHBOARD_REDIRECT_URIS 一条精确一致(如 https://<服务器>/cb)。
  "oidcDashboardRedirectUri": "",
  // 管理会话有效期(分钟):监考员登录后凭证寿命,建议 ≥ 考试时长。默认 180。
  "adminSessionMinutes": 180,
  // ---- HTTPS(远端监考工作站 OIDC 回调须 https;自签证书启动生成)。Urls 含 https 时生效 ----
  // 额外 SAN 主机/IP(逗号分隔):填服务器 LAN IP / 主机名,监考机才能验通证书(localhost/127.0.0.1 自动含)。
  "httpsSanHosts": "",
  "riskThreshold": 50,
  "dedupImagesByPhash": true,
  "onlineWindowSeconds": 90,
  "recentRiskWindowSeconds": 300,
  // M3 归档 / 清理(architecture §13/§15):考试**结束**超 RetentionDays 天后,关键数据(可疑/裁决/高危事件+其证据图/OCR/击键)
  //   转入 archive 库、其余就地清理、status='archived'、VACUUM 回收空间。仍有 pending 未裁决的考试会**跳过**(不 purge 未决案证据)。
  "archiveEnabled": true,
  "retentionDays": 30,
  // 关键数据判据:事件有效风险(max(agent,server))≥ 此值,或被 suspicious_queue 引用。
  "archiveCriticalRisk": 50,
  // 归档库文件(相对 dataDir);后台扫描间隔小时(≤0=关后台,仍可手动 POST /api/archive/run 触发)。
  "archiveDbPath": "horus-archive.db",
  "archiveScanIntervalHours": 6,
  // 视觉分析(L2:视觉 LLM 取代 OCR + L3 Logo,合并单一视觉级)。一次调用做文字提取+界面/图标识别+分类。
  // visionProvider: 留空/off=关(默认) | mock(确定性·联调) | openai(OpenAI 兼容端点)。
  //   openai 通吃小米 MiMo-V2.5 / DeepSeek-V4 / Qwen-VL / GLM-4V —— 换供应商=换 baseUrl+model+key。
  //   ★ owner 选定 = 小米 MiMo-V2.5 托管 API(境内云,OpenAI 兼容):
  "visionProvider": "openai",
  "visionBaseUrl": "https://token-plan-cn.xiaomimimo.com/v1",
  "visionModel": "mimo-v2.5",
  // ★ API key:在 **server.config.json**(非本 sample)里把明文填到 visionApiKey,服务器启动会**自动加密**为下面的 visionApiKeyEnc 并**清空本字段**。
  "visionApiKey": "",
  // 自动生成的 DPAPI 密文(机器绑定·勿手改)。也可用 `Horus.Server protect-secret <key>` 预生成后直接填这里、visionApiKey 留空。
  "visionApiKeyEnc": "",
  "visionConfidenceThreshold": 60,
  "visionAnalyzeBaseline": false,
  // 基线分析抽样率 N:visionAnalyzeBaseline=true 时只分析 1/N 的随机基线图(确定性按 imageId·跨重启一致·控云成本)。默认 1=全分析;设 10≈分析 10%。
  "visionBaselineSampleRate": 1,
  // 补偿重扫间隔(分钟):周期性拾回被队列丢弃/重启丢内存队列/临时云失败的未分析触发型证据图。默认 5;≤0=关闭。
  "visionBackstopMinutes": 5,
  // 单张图视觉分析最大认领次数(含失败):临时云失败由补偿重扫重试,达此上限放弃防死循环。默认 5。
  "visionMaxAttempts": 5,
  // §5 送云前派生处理(owner 决策 2026-07-02:不再打码/裁剪,只降采样;供应商=境内云 MiMo·PIPL 无跨境):
  //   visionMaxEdge: 送云图长边像素上限(降采样省 token·顺带剥离 EXIF/XMP/ICC 元数据)。默认 1600;0=不降采样直通。原图永不出网,只送派生图。
  "visionMaxEdge": 1600,
  // ---- M3 CLIP 按图搜图(provider-agnostic 嵌入器·C# 暴力余弦·无需 sqlite-vec·仅嵌证据图)----
  // embedProvider: 留空/"off"=关(默认) | "mock"(确定性·测试) | "onnx"(本地 CLIP ONNX·推荐·零出网) | "openai"(OpenAI 兼容 /v1/embeddings)。
  //   ★探测过:小米 MiMo-V2.5 **无** /v1/embeddings 端点(仅对话/视觉/ASR/TTS)→ 复用视觉 key 走不通,故用本地 onnx。
  //   部署前可 `Horus.Server probe-embed [model]` 探测某云端点是否有图像 embedding 模型。
  "embedProvider": "",
  // --- provider=onnx(本地 CLIP·推荐·零出网)---
  // embedOnnxModelPath: CLIP ViT-B/32 **图像编码器** ONNX(512 维)。★约定文件名 = model.onnx:
  //   **留空 = 默认找 dataDir\model.onnx**(与推荐仓原始文件名一致,下载免改名);放别处才显式填(相对 dataDir 或绝对)。
  //   下载(推荐·MIT·352MB): https://huggingface.co/Qdrant/clip-ViT-B-32-vision/resolve/main/model.onnx
  //   小体积备选(下载后**改名 model.onnx**): https://huggingface.co/Xenova/clip-vit-base-patch32/resolve/main/onnx/vision_model.onnx (或 vision_model_quantized.onnx int8)
  "embedOnnxModelPath": "",
  // embedOnnxInput / embedOnnxOutput: 张量名。**留空即可**——自动选(输入取首个;输出优先名含 embed/pool 的·正确取嵌入向量)。特殊模型用 Netron 看输出名再填。
  "embedOnnxInput": "",
  "embedOnnxOutput": "",
  // --- provider=openai(云·仅当有图像/多模态 embedding 端点时)---
  // embedBaseUrl: 留空则复用 visionBaseUrl(KEY一致);/embeddings 从此拼。embedModel/embedApiKey(留空复用视觉 key·env HORUS_EMBED_KEY)。
  "embedBaseUrl": "",
  "embedModel": "",
  "embedApiKey": "",
  // embedDim: 嵌入维度(暴力余弦无所谓·仅记录)。默认 512(CLIP ViT-B/32)。
  "embedDim": 512,
  // embedBackstopMinutes: 后台补嵌间隔(分钟)·拾回证据图里尚无 embedding 的。默认 5;≤0=关闭。
  "embedBackstopMinutes": 5
}